# Used by: npm run build:android (Vite --mode android loads .env.android).
# Copy to .env.android (or let `prebuild:android` create it once from this file).

# Offline-first: bundled JSON under public/data/ — no backend required on device.
VITE_DATA_MODE=local

# When you want the app to call your machine over Wi‑Fi (remote mode), set:
# VITE_DATA_MODE=remote
# VITE_API_URL=http://YOUR_PC_LAN_IP:5173/api
#
# Run backend: ./gradlew bootRun --args='--spring.profiles.active=local' (listens on 5173 per project config).
