{
  "name": "anti-doom-scroll",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && cd .. && firebase deploy",
    "prebuild:android": "node scripts/ensure-android-env.mjs",
    "export:journey-offline": "node scripts/export-journey-offline.mjs",
    "export:catalog-offline": "node scripts/export-catalog-offline.mjs",
    "export:ladder-offline": "node scripts/export-ladder-offline.mjs",
    "export:offline-data": "npm run export:journey-offline && npm run export:catalog-offline && npm run export:ladder-offline",
    "build:wordle-words": "node scripts/build-wordle-wordlists.mjs",
    "build:android": "tsc -b && vite build --mode android",
    "android:sync": "npm run build:android && npx cap sync android",
    "android:install": "npm run android:sync && cd android && .\\gradlew.bat installDebug --no-daemon"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.7.0",
    "happy-dom": "^20.7.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.3.0",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^4.0.18"
  }
}
